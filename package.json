{
  "name": "claude-code-structured-project",
  "version": "0.1.0",
  "description": "A template project demonstrating best practices for structuring a repository for Claude Code",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "@vitest/coverage-v8": "3.1.1",
    "eslint": "9.22.0",
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "prettier": "3.5.3",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "3.1.1"
  },
  "keywords": [
    "claude-code",
    "template",
    "structured-repo"
  ],
  "license": "MIT"
}
