{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(pytest *)",
      "Bash(pytest)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(mypy *)",
      "Bash(python *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git reset --hard)",
      "Read(.env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ruff format --check src/ tests/ 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-claude-md-size.sh"
          }
        ]
      }
    ]
  },
  "subagentConfiguration": {
    "Explore": {
      "model": "haiku"
    }
  }
}
