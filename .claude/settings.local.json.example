{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "_comment": "This is an EXAMPLE of personal settings. Copy to settings.local.json and customize.",
  "_comment2": "settings.local.json is in .gitignore and will NOT be committed.",

  "permissions": {
    "allow": [
      "Bash(git commit *)",
      "Bash(git checkout *)"
    ]
  },

  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "ghp_your_personal_token_here"
      }
    }
  },

  "subagentConfiguration": {
    "Explore": {
      "model": "haiku"
    }
  }
}
